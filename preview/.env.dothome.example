# 닷홈 shared hosting 빌드용 — scripts/build-dothome.ps1 가 각 패키지에 복사
# 도메인: http://study114.dothome.co.kr
# HTTPS 적용 후 아래 http:// 를 https:// 로 일괄 교체

VITE_HOME_UI_BASE=http://study114.dothome.co.kr
VITE_AUTH_UI_BASE=http://study114.dothome.co.kr/auth
VITE_SEARCH_UI_BASE=http://study114.dothome.co.kr/search
VITE_STUDY_ROOM_UI_BASE=http://study114.dothome.co.kr/register/room
VITE_TUTOR_UI_BASE=http://study114.dothome.co.kr/register/tutor

# 네이버 지도 (home-ui · search-ui 빌드 시 주입 — Client Secret 사용 안 함)
VITE_NAVER_MAP_CLIENT_ID=
