# 카페24 스테이징 — PHP 런타임 환경변수 예시
# 카페24는 .env 자동 로드 없음 → config/*.php 직접 반영 또는 호스팅 패널 설정
#
# FTP 아이디: study114new
# 도메인: https://study114new.mycafe24.com

STUDY114_API_BASE=https://study114new.mycafe24.com
STUDY114_HOME_UI=https://study114new.mycafe24.com
STUDY114_AUTH_UI=https://study114new.mycafe24.com/auth

STUDY114_DB_HOST=localhost
STUDY114_DB_PORT=3306
STUDY114_DB_NAME=__CAFE24_DB_NAME__
STUDY114_DB_USER=study114new
STUDY114_DB_PASS=__CAFE24_DB_PASSWORD__

# OAuth redirect (각 개발자 콘솔에 스테이징 URI 등록)
# https://study114new.mycafe24.com/api/auth/oauth/callback.php?provider=naver
# https://study114new.mycafe24.com/api/auth/oauth/callback.php?provider=kakao
# https://study114new.mycafe24.com/api/auth/oauth/callback.php?provider=google
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=
OAUTH_KAKAO_REST_API_KEY=
OAUTH_KAKAO_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

STUDY114_MAIL_FROM=noreply@study114.net
STUDY114_CRON_KEY=
STUDY114_STORAGE_SECRET=
