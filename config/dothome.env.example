# 닷홈 shared hosting — PHP 런타임 환경변수 예시
# 닷홈은 .env 자동 로드가 없음 → 아래 중 하나를 선택:
#   A) public/.htaccess 의 SetEnv 주석 해제 (권장)
#   B) config/database.php 등 파일에 직접 값 입력
#
# 도메인: http://study114.dothome.co.kr
# 웹루트: /hosting/study114/html
# FTP 아이디: study114

STUDY114_API_BASE=http://study114.dothome.co.kr
STUDY114_HOME_UI=http://study114.dothome.co.kr
STUDY114_AUTH_UI=http://study114.dothome.co.kr/auth
STUDY114_APP_ENV=production
STUDY114_DEBUG=0

STUDY114_DB_HOST=localhost
STUDY114_DB_PORT=3306
STUDY114_DB_NAME=study114
STUDY114_DB_USER=study114
STUDY114_DB_PASS=__DOTHOME_DB_PASSWORD__

# OAuth redirect (각 개발자 콘솔에 등록 — HTTPS 전환 후 URI도 https로 추가)
# http://study114.dothome.co.kr/api/auth/oauth/callback.php?provider=naver
# http://study114.dothome.co.kr/api/auth/oauth/callback.php?provider=kakao
# http://study114.dothome.co.kr/api/auth/oauth/callback.php?provider=google
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=
OAUTH_KAKAO_REST_API_KEY=
OAUTH_KAKAO_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

STUDY114_MAIL_FROM=noreply@study114.dothome.co.kr
STUDY114_CRON_KEY=__RANDOM_CRON_KEY__
STUDY114_STORAGE_SECRET=__RANDOM_STORAGE_SECRET__
