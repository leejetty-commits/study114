# 소셜 로그인 — 로컬·스테이징 환경 변수 예시
# 각 공급자 개발자 콘솔에 redirect URI 등록 후 값을 채운다.
#
# Redirect URI (공통 패턴):
#   http://127.0.0.1:8080/api/auth/oauth/callback.php?provider=naver
#   http://127.0.0.1:8080/api/auth/oauth/callback.php?provider=kakao
#   http://127.0.0.1:8080/api/auth/oauth/callback.php?provider=google
#
# Docker API 컨테이너에 전달:
#   docker compose -f docker/docker-compose.dev.yml up -d api
#   (docker-compose.dev.yml environment 섹션 참고)

STUDY114_API_BASE=http://127.0.0.1:8080
STUDY114_HOME_UI=http://127.0.0.1:5174
STUDY114_AUTH_UI=http://127.0.0.1:5173

OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=

OAUTH_KAKAO_REST_API_KEY=
# 카카오 Client Secret 사용 시에만 설정
OAUTH_KAKAO_CLIENT_SECRET=

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
