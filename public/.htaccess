# study114 — dothome minimal safe version

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 실제 파일/디렉터리는 그대로 제공
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # PHP MVC 인증 라우트
  RewriteRule ^auth/(login|logout|find-id|find-password)/?$ index.php [L,QSA]
  RewriteRule ^auth/signup/(terms|role|form|basic|complete)/?$ index.php [L,QSA]

  # SPA fallback
  RewriteRule ^auth/ auth/index.html [L]
  RewriteRule ^search/ search/index.html [L]
  RewriteRule ^register/room/ register/room/index.html [L]
  RewriteRule ^register/tutor/ register/tutor/index.html [L]

  # home-ui fallback
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteRule ^ index.html [L]
</IfModule>

DirectoryIndex index.html index.php
