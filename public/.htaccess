# study114 — dothome minimal safe version

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 실제 파일/디렉터리는 그대로 제공
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # PHP MVC 인증 라우트
  RewriteRule ^auth/(login|logout|find-id|find-password)/?$ index.php [L,QSA]
  RewriteRule ^auth/signup/(terms|role|form|basic|complete)/?$ index.php [L,QSA]

  # SPA fallback
  RewriteRule ^auth/ auth/index.html [L]
  RewriteRule ^search/ search/index.html [L]
  RewriteRule ^register/room/ register/room/index.html [L]
  RewriteRule ^register/tutor/ register/tutor/index.html [L]

  # home-ui fallback
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteRule ^ index.html [L]
</IfModule>

DirectoryIndex index.html index.php

# 닷홈: PHP OAuth·리다이렉트 URL (미설정 시 127.0.0.1 폴백 → 소셜 로그인 오류 시 localhost로 튕김)
<IfModule mod_env.c>
  SetEnv STUDY114_API_BASE http://study114.dothome.co.kr
  SetEnv STUDY114_HOME_UI http://study114.dothome.co.kr
  SetEnv STUDY114_AUTH_UI http://study114.dothome.co.kr/auth
  SetEnv STUDY114_APP_ENV production
  SetEnv STUDY114_DEBUG 0
  SetEnv OAUTH_NAVER_CLIENT_ID 6tjyX7FuwihrLSTkNkNx
  SetEnv OAUTH_NAVER_CLIENT_SECRET DWIUWqfnT0
  SetEnv OAUTH_KAKAO_REST_API_KEY c30e95c82362026606967bf5502beb62
  SetEnv OAUTH_KAKAO_CLIENT_SECRET 2X2HqZIqjNfOrpojfJZqb5QuIFKO13lz
  SetEnv OAUTH_GOOGLE_CLIENT_ID 679151474185-3smgti2t92d03pvgrlekkm0honn8elln.apps.googleusercontent.com
  SetEnv OAUTH_GOOGLE_CLIENT_SECRET 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
</IfModule>
